# API
DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres
JWT_SECRET=your-supabase-jwt-secret
MASKING_DOMAIN=anycode.com
PORT=3000

# Lambda (also needed locally for testing)
REDIS_URL=redis://localhost:6379
SES_BUCKET_NAME=shadow-ses-inbound
BOUNCE_FROM_ADDRESS=noreply@anycode.com
NOTIFY_FROM_ADDRESS=noreply@anycode.com
AWS_REGION=us-east-1

# Supabase (for CLI and migrations)
SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-db-password

# Vercel (set in GitHub Actions secrets)
VERCEL_TOKEN=...
VERCEL_ORG_ID=...
VERCEL_PROJECT_ID=...
