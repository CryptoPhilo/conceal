# API
DATABASE_URL=postgresql://neondb_owner:<password>@ep-<branch>-pooler.<region>.aws.neon.tech/neondb?channel_binding=require&sslmode=require
JWT_SECRET=your-jwt-secret-min-32-chars
MASKING_DOMAIN=anycode.com
PORT=3000

# Lambda (also needed locally for testing)
REDIS_URL=redis://localhost:6379
SES_BUCKET_NAME=shadow-ses-inbound
BOUNCE_FROM_ADDRESS=noreply@anycode.com
NOTIFY_FROM_ADDRESS=noreply@anycode.com
AWS_REGION=us-east-1

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Anthropic (Brain LLM)
ANTHROPIC_API_KEY=sk-ant-...

# Google Translate API (for translation scripts — see scripts/TRANSLATION_GUIDE.md)
GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key

# Vercel (set in GitHub Actions secrets)
VERCEL_TOKEN=...
VERCEL_ORG_ID=...
VERCEL_PROJECT_ID=...
