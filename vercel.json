{
  "version": 2,
  "installCommand": "npm ci",
  "buildCommand": "npm run build -w packages/shared && npm run build -w packages/web",
  "outputDirectory": "packages/web/.next",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/v1/:path*",
      "destination": "/api/index"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
