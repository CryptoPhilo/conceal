{
  "version": 2,
  "installCommand": "npm ci",
  "buildCommand": "",
  "functions": {
    "packages/api/api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/packages/api/api/index"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
