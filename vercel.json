{
  "version": 2,
  "buildCommand": "npm run build -w packages/api",
  "outputDirectory": "packages/api/dist",
  "installCommand": "npm ci",
  "functions": {
    "packages/api/api/index.ts": {
      "runtime": "nodejs20.x",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/packages/api/api/index.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
